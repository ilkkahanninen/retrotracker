{
  "name": "retrotracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A modern, web-based ProTracker module editor",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "render": "tsx tests/lib/render-cli.ts",
    "fixtures:generate": "tsx tests/fixtures/generate.ts",
    "pt2-clone:build": "bash vendor/build-pt2-clone.sh",
    "fixtures:render": "bash vendor/render-all-fixtures.sh"
  },
  "dependencies": {
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^2.1.8"
  }
}

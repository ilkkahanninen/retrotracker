{
  "name": "retrotracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A modern, web-based ProTracker module editor",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:server",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --target=node20 --packages=external --define:__APP_VERSION__=\\\"${APP_VERSION:-dev}\\\" --outfile=dist-server/index.mjs",
    "start": "node dist-server/index.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "render": "tsx tests/lib/render-cli.ts",
    "fixtures:generate": "tsx tests/fixtures/generate.ts",
    "fixtures:generate-xm": "tsx tests/fixtures/xm/generate.ts",
    "pt2-clone:build": "bash vendor/build-pt2-clone.sh",
    "fixtures:render": "bash vendor/render-all-fixtures.sh"
  },
  "dependencies": {
    "hono": "^4.12.18",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^2.1.8"
  }
}
